# ─── FRONTEND — Variáveis de Ambiente ───────────────────────────────────────
#
# PRODUÇÃO (Vercel):
#   Deixar VAZIO — o proxy do vercel.json repassa /api/* para o Koyeb.
#   O browser nunca faz chamada cross-origin.
#
# DESENVOLVIMENTO LOCAL:
#   Apontar para o backend local ou para o Koyeb diretamente.
#
# ─────────────────────────────────────────────────────────────────────────────

# Produção (Vercel) — deixar VAZIO:
VITE_API_URL=

# Dev local (backend rodando em localhost):
# VITE_API_URL=http://localhost:3001

# Dev local apontando para Koyeb (sem proxy):
# VITE_API_URL=https://extensive-avril-morph-d5a8aee2.koyeb.app
